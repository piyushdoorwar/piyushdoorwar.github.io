{
  "name": "piyushdoorwar.github.io",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Personal portfolio of Piyush Doorwar",
  "scripts": {
    "dev": "vite --port 5199 --strictPort",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "fetch-stats": "node scripts/fetch-stats.mjs",
    "fetch-medium": "node scripts/fetch-medium.mjs",
    "enrich-medium": "node scripts/enrich-medium.mjs",
    "fetch-data": "node scripts/fetch-stats.mjs && node scripts/fetch-medium.mjs"
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.2",
    "framer-motion": "^11.3.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  }
}
